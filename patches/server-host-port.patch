 package ip
 
 import (
+	"fmt"
+	"net"
 	"net/netip"
+	"strconv"
+	"strings"
 
 	mapset "github.com/deckarep/golang-set/v2"
 	"github.com/luskaner/ageLANServer/common"
 )
 
+type ListenTarget struct {
+	Addr netip.Addr
+	Port int
+}
+
+func ParseListenTargets(hosts mapset.Set[string], defaultPort int) (mapset.Set[ListenTarget], error) {
+	targets := mapset.NewThreadUnsafeSet[ListenTarget]()
+	for host := range hosts.Iter() {
+		parsedTargets, err := parseListenTargets(host, defaultPort)
+		if err != nil {
+			return nil, err
+		}
+		for target := range parsedTargets.Iter() {
+			targets.Add(target)
+		}
+	}
+	return targets, nil
+}
+
+func parseListenTargets(host string, defaultPort int) (mapset.Set[ListenTarget], error) {
+	targets := mapset.NewThreadUnsafeSet[ListenTarget]()
+	resolvedHost := host
+	port := defaultPort
+	if strings.Contains(host, ":") {
+		parsedHost, parsedPort, err := net.SplitHostPort(host)
+		if err != nil {
+			return nil, fmt.Errorf("invalid host entry %q: %w", host, err)
+		}
+		port, err = strconv.Atoi(parsedPort)
+		if err != nil || port < 1 || port > 65535 {
+			return nil, fmt.Errorf("invalid host entry %q: invalid port %q", host, parsedPort)
+		}
+		resolvedHost = parsedHost
+	}
+	addrs := ResolveHosts(mapset.NewThreadUnsafeSet[string](resolvedHost))
+	if addrs.IsEmpty() {
+		return targets, nil
+	}
+	for addr := range addrs.Iter() {
+		targets.Add(ListenTarget{Addr: addr, Port: port})
+	}
+	return targets, nil
+}
