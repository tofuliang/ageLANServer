--- /dev/null
+++ b/server/internal/ip/ip_test.go
@@ -0,0 +1,50 @@
+package ip
+
+import (
+	"testing"
+
+	mapset "github.com/deckarep/golang-set/v2"
+)
+
+func TestParseListenTargetsKeepsDefaultPortForPlainHost(t *testing.T) {
+	targets, err := ParseListenTargets(mapset.NewThreadUnsafeSet[string]("0.0.0.0"), 443)
+	if err != nil {
+		t.Fatalf("ParseListenTargets returned error: %v", err)
+	}
+	if targets.Cardinality() != 1 {
+		t.Fatalf("expected 1 target, got %d", targets.Cardinality())
+	}
+	for target := range targets.Iter() {
+		if target.Addr.String() != "0.0.0.0" {
+			t.Fatalf("expected addr 0.0.0.0, got %s", target.Addr)
+		}
+		if target.Port != 443 {
+			t.Fatalf("expected port 443, got %d", target.Port)
+		}
+	}
+}
+
+func TestParseListenTargetsUsesExplicitPortWhenProvided(t *testing.T) {
+	targets, err := ParseListenTargets(mapset.NewThreadUnsafeSet[string]("0.0.0.0:1234"), 443)
+	if err != nil {
+		t.Fatalf("ParseListenTargets returned error: %v", err)
+	}
+	if targets.Cardinality() != 1 {
+		t.Fatalf("expected 1 target, got %d", targets.Cardinality())
+	}
+	for target := range targets.Iter() {
+		if target.Addr.String() != "0.0.0.0" {
+			t.Fatalf("expected addr 0.0.0.0, got %s", target.Addr)
+		}
+		if target.Port != 1234 {
+			t.Fatalf("expected port 1234, got %d", target.Port)
+		}
+	}
+}
+
+func TestParseListenTargetsRejectsInvalidHostPort(t *testing.T) {
+	_, err := ParseListenTargets(mapset.NewThreadUnsafeSet[string]("0.0.0.0:not-a-port"), 443)
+	if err == nil {
+		t.Fatal("expected error for invalid host:port entry")
+	}
+}
